<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Default values -->
  <PropertyGroup>
    <Platforms>x64</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <Version>0.0.0.0</Version>

    <OverrideAssemblyName>true</OverrideAssemblyName>
  </PropertyGroup>
  
  <PropertyGroup>
    <_ConfigDir Condition="Exists('$(MSBuildProjectDirectory)/build/BuildResources.props')">$(MSBuildProjectDirectory)/build/</_ConfigDir>
    <_ConfigDir Condition="$(_ConfigDir) == '' AND Exists('$(MSBuildProjectDirectory)/../build/BuildResources.props')">$([MSBuild]::NormalizePath('$(MSBuildProjectDirectory)/../build/'))</_ConfigDir>
  </PropertyGroup>

  <Import Project="$(_ConfigDir)BuildResources.props"
          Condition="Exists('$(_ConfigDir)BuildResources.props')" />
  <Import Project="$(_ConfigDir)BuildResources.local.props"
          Condition="Exists('$(_ConfigDir)BuildResources.local.props')" />

  <PropertyGroup>
    <BuildForWindows>true</BuildForWindows>
    <BuildForWindowsStore>false</BuildForWindowsStore>
    <PostBuildCopyToModulesRegex>.*\.dll|.*\.pdb|.*\.config$</PostBuildCopyToModulesRegex>
    <ExcludeSourceFilesFromModule>true</ExcludeSourceFilesFromModule>
  </PropertyGroup>

  <PropertyGroup>
    <GameFolder>$(BANNERLORD_GAME_DIR)</GameFolder>
  </PropertyGroup>

  <!--Automatic Path Resolution-->
  <PropertyGroup>
    <!--Windows-->
    <!--Get from Registry (not working with dotnet right now)-->
    <GameFolder Condition="!Exists($(GameFolder)) AND $(OS) == 'Windows_NT'">$(registry:HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\Steam App 261550@InstallLocation)</GameFolder>
    <!--Set a default value if registry value is missing-->
    <GameFolder Condition="!Exists($(GameFolder)) AND $(OS) == 'Windows_NT'">C:\Program Files (x86)\Steam\steamapps\common\Mount &amp; Blade II Bannerlord</GameFolder>
    <!--Unix-->
    <!--Set a default value if registry value is missing-->
    <GameFolder Condition="!Exists($(GameFolder)) AND $(OS) == 'Unix'">~/.steam/root/steamapps/common/Mount &amp; Blade II Bannerlord</GameFolder>
  </PropertyGroup>

  <PropertyGroup>
    <DllName>$(ModuleId)</DllName>
    <SubModuleClassType>$([System.Text.RegularExpressions.Regex]::Replace($(ModuleId),"[^a-zA-Z0-9]","_"))</SubModuleClassType>
    <ModuleIdXml>$(ModuleId)</ModuleIdXml>
    <ModuleNameXml>$(ModuleName)</ModuleNameXml>
  </PropertyGroup>

  <!-- Local build overrides -->
  <PropertyGroup Condition="'$(Version)' == '0.0.0.0'">
    <ModuleIdXml>$(ModuleIdXml).Local</ModuleIdXml>
    <ModuleNameXml>$(ModuleNameXml) (LOCAL)</ModuleNameXml>
  </PropertyGroup>

  <PropertyGroup>
    <!-- 1. Resolve file path deterministically -->
    <_SGVFilePath Condition="Exists('$(MSBuildProjectDirectory)\supported-game-versions.txt')">
      $(MSBuildProjectDirectory)\supported-game-versions.txt
    </_SGVFilePath>

    <_SGVFilePath Condition="'$(_SGVFilePath)' == '' AND Exists('$(MSBuildProjectDirectory)\..\supported-game-versions.txt')">
      $([MSBuild]::NormalizePath('$(MSBuildProjectDirectory)\..\supported-game-versions.txt'))
    </_SGVFilePath>

    <!-- 2. Read file only if it exists -->
    <_SGVRawText Condition="Exists('$(_SGVFilePath)')">
      $([System.IO.File]::ReadAllText('$(_SGVFilePath)'))
    </_SGVRawText>

    <!-- 3. Normalize newlines (important for MSBuild split safety) -->
    <_SGVNormalized>
      $([System.String]::Copy('$(_SGVRawText)').Replace('\r\n', '\n').Replace('\r', '\n'))
    </_SGVNormalized>

    <!-- 4. First line (no regex) -->
    <_SGVFirstLine Condition="'$(_SGVNormalized)' != '' and $([System.String]::Copy('$(_SGVNormalized)').Contains('\n'))">
      $([System.String]::Copy('$(_SGVNormalized)').Split('\n')[0])
    </_SGVFirstLine>

    <_SGVFirstLine Condition="'$(_SGVNormalized)' != '' and ! $([System.String]::Copy('$(_SGVNormalized)').Contains('\n'))">
      $(_SGVNormalized)
    </_SGVFirstLine>

    <!-- 5. Last line -->
    <_SGVLastLine Condition="'$(_SGVNormalized)' != ''">
      $([System.String]::Copy('$(_SGVNormalized)').Split('\n')[ $([System.Array]::GetLength($([System.String]::Copy('$(_SGVNormalized)').Split('\n')) , 0)) - 1 ])
    </_SGVLastLine>

    <!-- 6. Fallback -->
    <GameVersionFallback>v1.0.0</GameVersionFallback>

    <!-- 7. Final values -->
    <GameVersionWithPrefix Condition="'$(_SGVFirstLine)' != ''">
      $(_SGVFirstLine)
    </GameVersionWithPrefix>

    <GameVersionWithPrefix Condition="'$(_SGVFirstLine)' == ''">
      $(GameVersionFallback)
    </GameVersionWithPrefix>

    <GameVersion Condition="'$(GameVersionWithPrefix)' != ''">
      $([System.String]::Copy('$(GameVersionWithPrefix)').Substring(1))
    </GameVersion>

    <GameMinimalVersion>$(_SGVLastLine)</GameMinimalVersion>
  </PropertyGroup>

  <PropertyGroup Condition="$(OverrideGameVersion) != ''">
    <GameVersionWithPrefix>$(OverrideGameVersion)</GameVersionWithPrefix>
    <GameVersion>$(GameVersionWithPrefix.Substring(1))</GameVersion>
  </PropertyGroup>

  <PropertyGroup>
    <GameVersionFlat>$([System.String]::Copy('$(GameVersion)').Replace('.',''))</GameVersionFlat>
    <GameVersionConstant>v$(GameVersionFlat)</GameVersionConstant>
    <DefineConstants>$(DefineConstants);$(GameVersionConstant)</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="$(OverrideAssemblyName) == 'true'">
    <AssemblyName>$(ModuleId).$(GameVersionWithPrefix)</AssemblyName>
  </PropertyGroup>

  <PropertyGroup>
    <GameMinor>$([System.Convert]::ToInt32($([System.String]::Copy('$(GameVersion)').Split('.')[1])))</GameMinor>

    <DefineConstants Condition="$(GameMinor) &lt; 1">$(DefineConstants);LOWER_THAN_1_2</DefineConstants>
    <DefineConstants Condition="$(GameMinor) &lt; 2">$(DefineConstants);LOWER_THAN_1_2</DefineConstants>
    <DefineConstants Condition="$(GameMinor) &lt; 3">$(DefineConstants);LOWER_THAN_1_3</DefineConstants>
    <DefineConstants Condition="$(GameMinor) &lt; 4">$(DefineConstants);LOWER_THAN_1_4</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <SubModuleOverrides Include="GameVersion" Condition="$(GameMinimalVersion) != ''">
      <Regex>\$gameversion\$</Regex>
      <Replacement>$(GameMinimalVersion)</Replacement>
    </SubModuleOverrides>
  </ItemGroup>

</Project>