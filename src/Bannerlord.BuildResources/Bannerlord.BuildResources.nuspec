<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2011/10/nuspec.xsd">
  <metadata>
    <id>Bannerlord.BuildResourcesLite</id>
    <version>$version$</version>
    <title>Bannerlord Build Resources Lite</title>
    <owners>adwitkow</owners>
    <authors>adwitkow, BUTR</authors>
    <description>Fork of Bannerlord.BuildResources for building Bannerlord modules and tools.</description>
    <developmentDependency>true</developmentDependency>
    <license type="expression">MIT</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <repository type="git" url="https://github.com/adwitkow/Bannerlord.BuildResourcesLite.git" />
    <tags></tags>
  </metadata>
  <files>
    <file src="build\*.*" target="build" />
  </files>
</package>
